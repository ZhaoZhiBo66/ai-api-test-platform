# Secrets. Without this, COPY . . bakes the real database password and the
# OpenAI key into the image, readable by anyone who can run it.
.env

# The host's virtualenv: ~70MB of platform-specific wheels, useless in the
# image, which builds its own from requirements.txt.
.venv/
.venv-codex/

.git/
.github/
.idea/

__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Runtime output, recreated in the container.
logs/
reports/
*.db

# Regenerated on every POST /reports/allure.
tests/generated_api_tests.py

# Note: tests/ itself is deliberately kept. generate_pytest_file writes into
# it and write_text does not create the parent directory, so the Allure
# endpoint fails with FileNotFoundError if the directory is missing. pytest is
# a runtime dependency here -- the platform shells out to it.
